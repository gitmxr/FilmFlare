# Server-only API keys (used by Next.js API routes — never expose to client)
TMDB_API_KEY=your_tmdb_api_key_here
YOUTUBE_API_KEY=your_youtube_api_key_here

# Development site URL for metadata/canonical links
NEXT_PUBLIC_SITE_URL=your_development_site_url_here

# Production site URL for metadata/canonical links
NEXT_PUBLIC_SITE_URL=your_production_site_url_here

